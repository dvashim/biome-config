{
  "name": "@dvashim/biome-config",
  "version": "1.10.3",
  "description": "Shared Biome Configurations",
  "keywords": [
    "biome",
    "config",
    "formatter",
    "lint"
  ],
  "homepage": "https://github.com/dvashim/biome-config#readme",
  "bugs": {
    "url": "https://github.com/dvashim/biome-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dvashim/biome-config.git"
  },
  "license": "MIT",
  "author": {
    "name": "Aleksei Reznichenko",
    "email": "aleksei@dvashim.dev"
  },
  "contributors": [
    {
      "name": "Galina Makarchuk",
      "email": "galya.makarchuk@gmail.com"
    }
  ],
  "type": "module",
  "exports": {
    ".": "./dist/biome.recommended.json",
    "./react-balanced": "./dist/biome.react-balanced.json",
    "./react-balanced-stable": "./dist/biome.react-balanced-stable.json",
    "./react-recommended": "./dist/biome.react-recommended.json",
    "./react-strict": "./dist/biome.react-strict.json",
    "./react-strict-stable": "./dist/biome.react-strict-stable.json",
    "./react/balanced": "./dist/biome.react-balanced.json",
    "./react/balanced-stable": "./dist/biome.react-balanced-stable.json",
    "./react/recommended": "./dist/biome.react-recommended.json",
    "./react/strict": "./dist/biome.react-strict.json",
    "./react/strict-stable": "./dist/biome.react-strict-stable.json",
    "./recommended": "./dist/biome.recommended.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "changeset": "changeset",
    "check": "pnpm run \"/^check:.*/\"",
    "check:format": "biome format",
    "check:publint": "publint --strict",
    "check:sync-stable": "node scripts/sync-stable.ts --check",
    "check:types": "tsc --noEmit",
    "sync-stable": "node scripts/sync-stable.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@types/node": "^26.1.1",
    "publint": "^0.3.22",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@11.17.0+sha512.cca3cea332ad254bb84145f966d19f4879615210346fc92c79a047f23a0d7b3cca3c3792f0076ba1f1831d277efbcf0a9119b31a9a60eca7fb3d6231f331ef72",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
