  "description": "Shared Biome Configurations",
  "keywords": [
    "biome",
    "config",
    "formatter",
    "lint"
  ],
  "homepage": "https://github.com/dvashim/biome-config#readme",
  "bugs": {
    "url": "https://github.com/dvashim/biome-config/issues"
  },
