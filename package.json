{
  "name": "@dvashim/biome-config",
  "version": "1.10.1",
  "description": "Shared Biome Configurations",
  "keywords": [
    "biome",
    "config",
    "formatter",
    "lint"
  ],
  "homepage": "https://github.com/dvashim/biome-config#readme",
  "bugs": {
    "url": "https://github.com/dvashim/biome-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dvashim/biome-config.git"
  },
  "license": "MIT",
  "author": {
    "name": "Aleksei Reznichenko",
    "email": "aleksei@dvashim.dev"
  },
  "contributors": [
    {
      "name": "Galina Makarchuk",
      "email": "galya.makarchuk@gmail.com"
    }
  ],
  "type": "module",
  "exports": {
    ".": "./dist/biome.recommended.json",
    "./react-balanced": "./dist/biome.react-balanced.json",
    "./react-balanced-stable": "./dist/biome.react-balanced-stable.json",
    "./react-recommended": "./dist/biome.react-recommended.json",
    "./react-strict": "./dist/biome.react-strict.json",
    "./react-strict-stable": "./dist/biome.react-strict-stable.json",
    "./react/balanced": "./dist/biome.react-balanced.json",
    "./react/balanced-stable": "./dist/biome.react-balanced-stable.json",
    "./react/recommended": "./dist/biome.react-recommended.json",
    "./react/strict": "./dist/biome.react-strict.json",
    "./react/strict-stable": "./dist/biome.react-strict-stable.json",
    "./recommended": "./dist/biome.recommended.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "changeset": "changeset",
    "check": "pnpm run \"/^check:.*/\"",
    "check:exports": "validate-package-exports --check",
    "check:format": "biome format",
    "check:sync-stable": "node scripts/sync-stable.mjs --check",
    "sync-stable": "node scripts/sync-stable.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "validate-package-exports": "^1.2.1"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
