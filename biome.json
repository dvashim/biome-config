{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "extends": ["dist/biome.recommended.jsonc"],
  "root": true,
  "assist": {
    "actions": {
      "source": {
        "useSortedKeys": {
          "level": "on",
          "options": {
            "groupByNesting": true
          }
        }
      }
    }
  },
  "files": {
    "includes": ["**"]
  },
  "overrides": [
    {
      "includes": ["./.claude/settings.local.json"],
      "json": {
        "formatter": {
          "expand": "always"
        }
      }
    },
    {
      "includes": ["./package.json"],
      "assist": {
        "actions": {
          "source": {
            "useSortedKeys": "off"
          }
        }
      }
    }
  ]
}
